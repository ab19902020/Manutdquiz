// by padding with solid variant questions about standard trivia.
const PADDED_QUESTIONS = [
  ...INTERNAL_QUESTIONS,
  { question: "In what year did Manchester United win their first ever League title?", options: ["1905", "1908", "1911", "1920"], correct: 1 },
  { question: "Who was the manager of Manchester United when they won their first League title?", options: ["Ernest Mangnall", "Jack Robson", "Scott Duncan", "Matt Busby"], correct: 0 },
