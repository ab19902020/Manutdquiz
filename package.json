{
  "name": "manutdquiz",
  "version": "1.0.0",
  "private": true,
  "description": "Manchester United Pub Quiz - a standalone React trivia game.",
  "scripts": {
    "build:js": "babel src/app.jsx -o app.js --presets @babel/preset-react",
    "build:css": "tailwindcss -i src/input.css -o styles.css --minify",
    "build": "npm run build:js && npm run build:css"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "tailwindcss": "^3.4.0"
  }
}
